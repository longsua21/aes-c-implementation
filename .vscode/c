#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <ctype.h>

int is_valid(const char *num, int base) {
    int i = 0;
    while (num[i]) {
        char c = toupper(num[i]);
        if (base == 2) {
            if (c != '0' && c != '1') return 0;
        } else if (base == 10) {
            if (!isdigit(c)) return 0;
        } else if (base == 16) {
            if (!((c >= '0' && c <= '9') || (c >= 'A' && c <= 'F'))) return 0;
        }
        i++;
    }
    return 1;
}

void convert_and_print(const char *num, int src_base, int dest_base) {
    // Chuyển chuỗi num hệ src_base sang số int rồi in ra hệ dest_base
    char *endptr;
    long value = strtol(num, &endptr, src_base);
    if (*endptr != '\0') {
        printf("Số nhập không hợp lệ cho hệ %d.\n", src_base);
        return;
    }

    if (dest_base == 2) {
        // in nhị phân
        if (value == 0) {
            printf("0\n");
            return;
        }
        char bin[65];
        bin[64] = '\0';
        int idx = 63;
        unsigned long uvalue = (unsigned long)value;
        while (uvalue > 0) {
            bin[idx--] = (uvalue % 2) ? '1' : '0';
            uvalue /= 2;
        }
        printf("%s\n", &bin[idx + 1]);
    } else if (dest_base == 10) {
        printf("%ld\n", value);
    } else if (dest_base == 16) {
        printf("%lX\n", value);
    }
}

int main() {
    int src_base, dest_base;
    char num[100];

    printf("Các hệ số:\n");
    printf("1 - Nhị phân (Base 2)\n");
    printf("2 - Thập phân (Base 10)\n");
    printf("3 - Thập lục phân (Base 16)\n");

    printf("Chọn hệ nhập số (1,2 hoặc 3): ");
    int choice1;
    scanf("%d", &choice1);
    if (choice1 < 1 || choice1 > 3) {
        printf("Lựa chọn không hợp lệ.\n");
        return 1;
    }
    if (choice1 == 1) src_base = 2;
    else if (choice1 == 2) src_base = 10;
    else src_base = 16;

    printf("Nhập số theo hệ đã chọn: ");
    scanf("%s", num);
    if (!is_valid(num, src_base)) {
        printf("Số nhập không hợp lệ cho hệ %d.\n", src_base);
        return 1;
    }

    printf("Chọn hệ cần chuyển đổi sang (1,2 hoặc 3): ");
    int choice2;
    scanf("%d", &choice2);
    if (choice2 < 1 || choice2 > 3) {
        printf("Lựa chọn không hợp lệ.\n");
        return 1;
    }
    if (choice2 == 1) dest_base = 2;
    else if (choice2 == 2) dest_base = 10;
    else dest_base = 16;

    if (src_base == dest_base) {
        printf("Hệ nguồn và hệ đích giống nhau, số ban đầu là: %s\n", num);
        return 0;
    }

    printf("Kết quả: ");
    convert_and_print(num, src_base, dest_base);

    return 0;
}

